---
import type { Reference } from '../types';

interface Props {
  reference: Reference;
}

const { reference } = Astro.props;
---

<label class="flex items-start gap-3 py-2 px-3 rounded-md hover:bg-surface-hover dark:hover:bg-dark-surface-hover transition-colors cursor-pointer group">
  <input
    type="checkbox"
    data-reference-id={reference.id}
    class="mt-0.5 h-4 w-4 shrink-0 rounded border-border dark:border-dark-border text-accent dark:text-dark-accent accent-accent dark:accent-dark-accent cursor-pointer"
  />
  <a
    href={reference.url}
    target="_blank"
    rel="noopener noreferrer"
    title={reference.summary}
    class="text-sm text-text-primary dark:text-dark-text-primary hover:text-accent dark:hover:text-dark-accent transition-colors break-words"
    onclick="event.stopPropagation()"
  >
    {reference.title}
    <svg class="inline-block w-3 h-3 ml-0.5 opacity-0 group-hover:opacity-50 transition-opacity" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
    </svg>
  </a>
</label>
