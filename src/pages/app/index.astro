---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import iphoneHome from '../../assets/app-screenshots/iphone-home.png';
import ipadHome from '../../assets/app-screenshots/ipad-home.png';
import macHome from '../../assets/app-screenshots/mac-home.png';
import iphonePaywall from '../../assets/app-screenshots/iphone-paywall.png';
import iphoneQuizQuestion from '../../assets/app-screenshots/iphone-quiz-question.png';
import iphoneQuizReview from '../../assets/app-screenshots/iphone-quiz-review.png';
import macQuiz from '../../assets/app-screenshots/mac-quiz.png';

const APP_STORE_IOS = 'https://apps.apple.com/app/sfce-learning/id6764245530';
const APP_STORE_MAC = 'https://apps.apple.com/pl/app/sfce-learning/id6764245530?mt=12';
---

<BaseLayout
  title="SFCE Learning App — Symfony Certification Study Guide for iPhone, iPad & Mac"
  description="Native Apple app for the Symfony Framework Certification Exam. Browse topics, chapters, and references; track progress offline with iCloud sync, Calendar, and Reminders integration."
  canonicalPath="/app/"
  footerVariant="app"
>
  <!-- Hero -->
  <section class="py-16 sm:py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-block mb-4 text-xs font-medium px-3 py-1 rounded-full bg-accent/10 dark:bg-dark-accent/20 text-accent dark:text-dark-accent">
        Available on the App Store
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold text-text-primary dark:text-dark-text-primary mb-4 tracking-tight">
        SFCE Learning <span class="text-accent dark:text-dark-accent">on Apple devices</span>
      </h1>
      <p class="text-lg sm:text-xl text-text-secondary dark:text-dark-text-secondary max-w-2xl mx-auto mb-10">
        A native iPhone, iPad, and Mac companion for your Symfony Framework Certification Exam preparation.
        Same content as <a href={import.meta.env.BASE_URL} class="text-accent dark:text-dark-accent hover:underline">sfcelearning.com</a> &mdash; offline, fast, and at home on Apple platforms.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          class="app-store-badge"
          href={APP_STORE_IOS}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download SFCE Learning on the App Store for iPhone and iPad"
        >
          <img class="badge-dark" src={`${import.meta.env.BASE_URL}badges/app-store-ios-black.svg`} alt="Download on the App Store" height="48" width="143.6" />
          <img class="badge-light" src={`${import.meta.env.BASE_URL}badges/app-store-ios-white.svg`} alt="Download on the App Store" height="48" width="143.6" />
        </a>
        <a
          class="app-store-badge"
          href={APP_STORE_MAC}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download SFCE Learning on the Mac App Store"
        >
          <img class="badge-dark" src={`${import.meta.env.BASE_URL}badges/mac-app-store-black.svg`} alt="Download on the Mac App Store" height="48" width="187.3" />
          <img class="badge-light" src={`${import.meta.env.BASE_URL}badges/mac-app-store-white.svg`} alt="Download on the Mac App Store" height="48" width="187.3" />
        </a>
      </div>

      <p class="mt-6 text-sm text-text-muted dark:text-dark-text-muted">
        For iPhone, iPad, and Mac &mdash; iOS / iPadOS / macOS 26.4 or later.
      </p>
    </div>
  </section>

  <!-- Device showcase -->
  <section class="pb-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-text-primary dark:text-dark-text-primary text-center mb-3">
        At home on every Apple device
      </h2>
      <p class="text-center text-text-secondary dark:text-dark-text-secondary max-w-2xl mx-auto mb-12">
        Free to download on iPhone, iPad, and Mac. Progress syncs through iCloud so you can pick up exactly where you left off.
      </p>

      <!-- Hero device composition: Mac in back, iPad in front-left, iPhone in front-right -->
      <div class="relative mx-auto max-w-4xl">
        <!-- Mac (laptop) -->
        <div class="mx-auto w-full max-w-3xl">
          <div class="rounded-t-xl bg-neutral-800 dark:bg-neutral-900 p-[10px] pb-2 shadow-2xl ring-1 ring-black/10">
            <div class="overflow-hidden rounded-md bg-black">
              <Image
                src={macHome}
                alt="SFCE Learning app running on macOS, showing the Symfony 8.0 topics home screen"
                widths={[640, 1024, 1600]}
                sizes="(max-width: 768px) 90vw, 720px"
                class="block w-full h-auto"
              />
            </div>
          </div>
          <!-- Laptop base -->
          <div class="mx-auto h-3 w-[105%] -mt-[1px] rounded-b-lg bg-gradient-to-b from-neutral-700 to-neutral-800 dark:from-neutral-800 dark:to-neutral-900 shadow-md"></div>
          <div class="mx-auto h-1.5 w-[60%] rounded-b-xl bg-neutral-300/60 dark:bg-neutral-700/60"></div>
        </div>

        <!-- iPad — front left -->
        <div class="absolute -bottom-6 sm:-bottom-10 left-0 sm:left-6 w-[34%] sm:w-[30%] max-w-[260px]">
          <div class="rounded-[18px] sm:rounded-[24px] bg-neutral-900 dark:bg-neutral-950 p-[6px] sm:p-[8px] shadow-2xl ring-1 ring-black/10 rotate-[-4deg]">
            <div class="overflow-hidden rounded-[12px] sm:rounded-[18px] bg-black">
              <Image
                src={ipadHome}
                alt="SFCE Learning on iPad showing the topic list"
                widths={[240, 360, 480]}
                sizes="(max-width: 640px) 30vw, 240px"
                class="block w-full h-auto"
              />
            </div>
          </div>
        </div>

        <!-- iPhone — front right -->
        <div class="absolute -bottom-8 sm:-bottom-14 right-0 sm:right-8 w-[18%] sm:w-[16%] max-w-[140px]">
          <div class="rounded-[20px] sm:rounded-[28px] bg-neutral-900 dark:bg-neutral-950 p-[4px] sm:p-[5px] shadow-2xl ring-1 ring-black/20 rotate-[5deg]">
            <div class="relative overflow-hidden rounded-[16px] sm:rounded-[24px] bg-black">
              <!-- Dynamic Island -->
              <div class="absolute top-1.5 left-1/2 -translate-x-1/2 z-10 w-[28%] h-[6px] sm:h-[8px] rounded-full bg-black"></div>
              <Image
                src={iphoneHome}
                alt="SFCE Learning on iPhone showing the topic list"
                widths={[160, 240, 360]}
                sizes="(max-width: 640px) 18vw, 140px"
                class="block w-full h-auto"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Spacer so floating devices don't crash into next section -->
      <div class="h-16 sm:h-24"></div>
    </div>
  </section>

  <!-- Features -->
  <section class="pb-20 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Fully Offline</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">All topics, chapters, and references are bundled with the app. No network required for core functionality.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">iCloud Sync</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Completed references sync between your iPhone, iPad, and Mac through your iCloud account.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Calendar &amp; Reminders</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Schedule study sessions or create reminders for any chapter or reference straight from the app.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Progress Tracking</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Track completed references per chapter, topic, and Symfony version &mdash; 8.0, 7.0, and 6.0.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Privacy First</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">No accounts, no analytics, no tracking. Study data stays on your device and your iCloud account.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Built for Apple</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Written in Swift &amp; SwiftUI. Light and dark mode follow your system appearance automatically.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Test your knowledge — In-App Purchase -->
  <section class="pb-24 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <span class="inline-block mb-4 text-xs font-medium px-3 py-1 rounded-full bg-accent/10 dark:bg-dark-accent/20 text-accent dark:text-dark-accent">
          In-App Purchase &mdash; lifetime access
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-text-primary dark:text-dark-text-primary mb-4">
          Test your knowledge
        </h2>
        <p class="text-text-secondary dark:text-dark-text-secondary max-w-2xl mx-auto">
          Unlock practice quizzes with a one-time purchase &mdash; no subscriptions, no expirations.
          Thousands of questions across Symfony 6.0, 7.0, and 8.0, with instant answer review so you
          learn from every mistake.
        </p>
      </div>

      <!-- iPhone trio: Paywall → Question → Review -->
      <div class="grid grid-cols-3 gap-3 sm:gap-8 items-start max-w-3xl mx-auto">
        <div class="flex flex-col items-center">
          <div class="w-full">
            <div class="rounded-[20px] sm:rounded-[36px] bg-neutral-900 dark:bg-neutral-950 p-[4px] sm:p-[6px] shadow-xl ring-1 ring-black/20">
              <div class="relative overflow-hidden rounded-[16px] sm:rounded-[32px] bg-black">
                <div class="absolute top-1.5 sm:top-2 left-1/2 -translate-x-1/2 z-10 w-[28%] h-[6px] sm:h-[10px] rounded-full bg-black"></div>
                <Image
                  src={iphonePaywall}
                  alt="SFCE Learning paywall on iPhone showing lifetime in-app purchase"
                  widths={[200, 320, 480]}
                  sizes="(max-width: 640px) 30vw, 220px"
                  class="block w-full h-auto"
                />
              </div>
            </div>
          </div>
          <p class="mt-4 text-xs sm:text-sm font-medium text-text-primary dark:text-dark-text-primary">Unlock once</p>
          <p class="mt-1 text-xs text-text-muted dark:text-dark-text-muted text-center">Lifetime purchase</p>
        </div>

        <div class="flex flex-col items-center">
          <div class="w-full">
            <div class="rounded-[20px] sm:rounded-[36px] bg-neutral-900 dark:bg-neutral-950 p-[4px] sm:p-[6px] shadow-xl ring-1 ring-black/20">
              <div class="relative overflow-hidden rounded-[16px] sm:rounded-[32px] bg-black">
                <div class="absolute top-1.5 sm:top-2 left-1/2 -translate-x-1/2 z-10 w-[28%] h-[6px] sm:h-[10px] rounded-full bg-black"></div>
                <Image
                  src={iphoneQuizQuestion}
                  alt="Quiz question screen on iPhone"
                  widths={[200, 320, 480]}
                  sizes="(max-width: 640px) 30vw, 220px"
                  class="block w-full h-auto"
                />
              </div>
            </div>
          </div>
          <p class="mt-4 text-xs sm:text-sm font-medium text-text-primary dark:text-dark-text-primary">Practice</p>
          <p class="mt-1 text-xs text-text-muted dark:text-dark-text-muted text-center">Real exam-style questions</p>
        </div>

        <div class="flex flex-col items-center">
          <div class="w-full">
            <div class="rounded-[20px] sm:rounded-[36px] bg-neutral-900 dark:bg-neutral-950 p-[4px] sm:p-[6px] shadow-xl ring-1 ring-black/20">
              <div class="relative overflow-hidden rounded-[16px] sm:rounded-[32px] bg-black">
                <div class="absolute top-1.5 sm:top-2 left-1/2 -translate-x-1/2 z-10 w-[28%] h-[6px] sm:h-[10px] rounded-full bg-black"></div>
                <Image
                  src={iphoneQuizReview}
                  alt="Quiz review screen on iPhone showing correct and incorrect answers"
                  widths={[200, 320, 480]}
                  sizes="(max-width: 640px) 30vw, 220px"
                  class="block w-full h-auto"
                />
              </div>
            </div>
          </div>
          <p class="mt-4 text-xs sm:text-sm font-medium text-text-primary dark:text-dark-text-primary">Review</p>
          <p class="mt-1 text-xs text-text-muted dark:text-dark-text-muted text-center">Learn from every answer</p>
        </div>
      </div>

      <!-- Mac quiz screenshot below -->
      <div class="mt-16 sm:mt-20">
        <div class="mx-auto w-full max-w-3xl">
          <div class="rounded-t-xl bg-neutral-800 dark:bg-neutral-900 p-[10px] pb-2 shadow-2xl ring-1 ring-black/10">
            <div class="overflow-hidden rounded-md bg-black">
              <Image
                src={macQuiz}
                alt="SFCE Learning quiz running on macOS"
                widths={[640, 1024, 1600]}
                sizes="(max-width: 768px) 90vw, 720px"
                class="block w-full h-auto"
              />
            </div>
          </div>
          <div class="mx-auto h-3 w-[105%] -mt-[1px] rounded-b-lg bg-gradient-to-b from-neutral-700 to-neutral-800 dark:from-neutral-800 dark:to-neutral-900 shadow-md"></div>
          <div class="mx-auto h-1.5 w-[60%] rounded-b-xl bg-neutral-300/60 dark:bg-neutral-700/60"></div>
        </div>
        <p class="mt-8 text-center text-sm text-text-secondary dark:text-dark-text-secondary">
          Same quizzes &mdash; with a bigger window &mdash; on iPad and Mac.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
