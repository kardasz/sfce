---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTopics } from '../data/versions';
import { VERSIONS } from '../types';

const versionStats = VERSIONS.map(version => {
  const topics = getTopics(version);
  const totalChapters = topics.reduce((sum, t) => sum + t.chapters.length, 0);
  const totalRefs = topics.reduce((sum, t) => sum + t.chapters.reduce((s, c) => s + c.references.length, 0), 0);
  return { version, topicCount: topics.length, chapterCount: totalChapters, refCount: totalRefs };
});
---

<BaseLayout
  title="SFCE Learning — Symfony Certification Exam Study Guide"
  description="Free, open-source study guide for the Symfony Framework Certification Exam. Track your progress through topics, chapters, and references for Symfony 8.0, 7.0 and 6.0."
  canonicalPath="/"
>
  <!-- Hero -->
  <section class="py-16 sm:py-24 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-text-primary dark:text-dark-text-primary mb-4 tracking-tight">
        Prepare for the <span class="text-accent dark:text-dark-accent">Symfony Certification</span> Exam
      </h1>
      <p class="text-lg sm:text-xl text-text-secondary dark:text-dark-text-secondary max-w-2xl mx-auto mb-10">
        A free, open-source study guide that helps you organize and track your preparation for the
        <a href="https://certification.symfony.com/" target="_blank" rel="noopener noreferrer" class="text-accent dark:text-dark-accent hover:underline">Symfony Framework Certification Exam</a>.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`${import.meta.env.BASE_URL}8.0/`}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-accent hover:bg-accent-hover text-white font-medium transition-colors text-base"
        >
          Start with Symfony 8.0
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href={`${import.meta.env.BASE_URL}7.0/`}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-border dark:border-dark-border text-text-primary dark:text-dark-text-primary hover:bg-surface-hover dark:hover:bg-dark-surface-hover font-medium transition-colors text-base"
        >
          Symfony 7.0 Guide
        </a>
        <a
          href={`${import.meta.env.BASE_URL}6.0/`}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-border dark:border-dark-border text-text-primary dark:text-dark-text-primary hover:bg-surface-hover dark:hover:bg-dark-surface-hover font-medium transition-colors text-base"
        >
          Symfony 6.0 Guide
        </a>
      </div>
    </div>
  </section>

  <!-- Version Cards -->
  <section class="pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-xl font-semibold text-text-primary dark:text-dark-text-primary mb-6 text-center">Available Study Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {versionStats.map(({ version, topicCount, chapterCount, refCount }) => (
          <a
            href={`${import.meta.env.BASE_URL}${version}/`}
            class:list={[
              "block rounded-xl border p-6 transition-all hover:shadow-lg group",
              version === '8.0'
                ? "border-accent/30 dark:border-dark-accent/30 bg-accent-light dark:bg-dark-accent-light"
                : "border-border dark:border-dark-border bg-surface dark:bg-dark-surface hover:border-accent/30 dark:hover:border-dark-accent/30"
            ]}
          >
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-lg font-bold text-text-primary dark:text-dark-text-primary group-hover:text-accent dark:group-hover:text-dark-accent transition-colors">
                  Symfony {version}
                </h3>
                {version === '8.0' && (
                  <span class="inline-block mt-1 text-xs font-medium px-2 py-0.5 rounded-full bg-accent/10 dark:bg-dark-accent/20 text-accent dark:text-dark-accent">
                    Latest
                  </span>
                )}
              </div>
              <svg class="w-5 h-5 text-text-muted dark:text-dark-text-muted group-hover:text-accent dark:group-hover:text-dark-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            </div>
            <div class="flex gap-4 text-sm text-text-secondary dark:text-dark-text-secondary">
              <span>{topicCount} topics</span>
              <span>{chapterCount} chapters</span>
              <span>{refCount} references</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="pb-20 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Progress Tracking</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Mark references as completed and track your study progress across all topics.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Privacy First</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">No accounts, no cookies, no tracking. All data stays in your browser.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Mobile Friendly</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Study on any device with a fully responsive design and dark mode support.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-light dark:bg-dark-accent-light flex items-center justify-center">
            <svg class="w-5 h-5 text-accent dark:text-dark-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-text-primary dark:text-dark-text-primary mb-1">Curated References</h3>
            <p class="text-sm text-text-secondary dark:text-dark-text-secondary">Direct links to official Symfony documentation and relevant resources for each topic.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
