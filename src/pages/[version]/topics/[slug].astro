---
import type { GetStaticPaths } from 'astro';
import Layout from '../../../layouts/Layout.astro';
import ChapterSection from '../../../components/ChapterSection.astro';
import { getTopics } from '../../../data/versions';
import type { Topic, SymfonyVersion } from '../../../types';
import { VERSIONS } from '../../../types';

export const getStaticPaths: GetStaticPaths = () => {
  return VERSIONS.flatMap(version =>
    getTopics(version).map(topic => ({
      params: { version, slug: topic.slug },
      props: { topic, version }
    }))
  );
};

interface Props {
  topic: Topic;
  version: SymfonyVersion;
}

const { topic, version } = Astro.props;
const totalRefs = topic.chapters.reduce((sum, ch) => sum + ch.references.length, 0);
const allRefIds = topic.chapters.flatMap(ch => ch.references.map(r => r.id));
---

<Layout title={`${topic.title} — SFCE ${version}`} currentSlug={topic.slug} version={version}>
  <div class="mb-6">
    <a
      href={`${import.meta.env.BASE_URL}${version}/`}
      class="inline-flex items-center gap-1 text-sm text-text-muted dark:text-dark-text-muted hover:text-accent dark:hover:text-dark-accent transition-colors mb-3"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      All Topics
    </a>
    <h1 class="text-2xl sm:text-3xl font-bold text-text-primary dark:text-dark-text-primary mb-1">
      {topic.title}
    </h1>
    <p class="text-sm text-text-secondary dark:text-dark-text-secondary">
      {topic.chapters.length} chapters &middot; {totalRefs} references &middot;
      <span data-topic-detail-progress data-reference-ids={JSON.stringify(allRefIds)}>0/{totalRefs}</span> completed
    </p>

    <div class="mt-3 h-2 rounded-full bg-progress-bg dark:bg-dark-progress-bg overflow-hidden">
      <div
        class="h-full rounded-full bg-progress transition-all duration-300"
        data-topic-detail-bar
        style="width: 0%"
      ></div>
    </div>
  </div>

  <div class="space-y-3">
    {topic.chapters.map((chapter, index) => (
      <ChapterSection chapter={chapter} index={index} />
    ))}
  </div>
</Layout>

<script>
  function updateAllProgress() {
    const versionEl = document.querySelector<HTMLElement>('[data-version]');
    const version = versionEl?.dataset.version || '8.0';
    const prefix = `sfce:${version}:`;

    // Restore checkbox states
    document.querySelectorAll<HTMLInputElement>('[data-reference-id]').forEach(checkbox => {
      const id = checkbox.dataset.referenceId!;
      checkbox.checked = localStorage.getItem(prefix + id) === 'true';

      checkbox.addEventListener('change', () => {
        localStorage.setItem(prefix + id, String(checkbox.checked));
        updateAllProgress();
      });
    });

    // Update chapter progress
    document.querySelectorAll<HTMLElement>('[data-chapter-progress]').forEach(el => {
      const ids: string[] = JSON.parse(el.dataset.referenceIds || '[]');
      const checked = ids.filter(id => localStorage.getItem(prefix + id) === 'true').length;
      el.textContent = `${checked}/${ids.length}`;
    });

    // Update topic detail progress
    const progressEl = document.querySelector<HTMLElement>('[data-topic-detail-progress]');
    const barEl = document.querySelector<HTMLElement>('[data-topic-detail-bar]');
    if (progressEl) {
      const ids: string[] = JSON.parse(progressEl.dataset.referenceIds || '[]');
      const checked = ids.filter(id => localStorage.getItem(prefix + id) === 'true').length;
      const pct = ids.length > 0 ? Math.round((checked / ids.length) * 100) : 0;
      progressEl.textContent = `${checked}/${ids.length}`;
      if (barEl) barEl.style.width = `${pct}%`;
    }

    // Update sidebar progress
    document.querySelectorAll<HTMLElement>('[data-progress-bar]').forEach(bar => {
      const slug = bar.dataset.progressBar!;
      const ids: string[] = JSON.parse(bar.dataset.referenceIds || '[]');
      const checked = ids.filter(id => localStorage.getItem(prefix + id) === 'true').length;
      const pct = ids.length > 0 ? Math.round((checked / ids.length) * 100) : 0;
      bar.style.width = `${pct}%`;

      const textEl = document.querySelector<HTMLElement>(`[data-progress-text="${slug}"]`);
      if (textEl) textEl.textContent = `${checked}/${ids.length}`;
    });

    // Update global progress
    let totalChecked = 0;
    let totalRefs = 0;
    document.querySelectorAll<HTMLElement>('[data-progress-bar]').forEach(bar => {
      const ids: string[] = JSON.parse(bar.dataset.referenceIds || '[]');
      totalRefs += ids.length;
      totalChecked += ids.filter(id => localStorage.getItem(prefix + id) === 'true').length;
    });
    const globalEl = document.getElementById('global-progress');
    if (globalEl && totalRefs > 0) {
      const pct = Math.round((totalChecked / totalRefs) * 100);
      globalEl.textContent = `${totalChecked}/${totalRefs} (${pct}%)`;
    }
  }

  updateAllProgress();
</script>
